# How often the scraper runs (default: every 6 hours)
SCRAPE_INTERVAL_HOURS=6

# Where SQLite stores data (default works for Docker)
DB_PATH=/app/data/trends.db

# Anthropic API key — required for AI content brief generation
# Get yours at: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Railway sets this automatically — don't change it
# PORT=5000
